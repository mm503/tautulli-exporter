{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch", "digest", "pin", "pinDigest"],
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps"
    }
  ]
}
